# LLM used by the LangGraph planning agent (LangChain init_chat_model string).
# Examples: openai:gpt-4o-mini, anthropic:claude-haiku-4-5
LANG2ACTION_MODEL=openai:gpt-4o-mini

# Perception backend: "sim" (ground-truth scene graph from PyBullet state)
# or "sgg" (real Lightweight SGG service over HTTP).
LANG2ACTION_PERCEPTION=sim

# URL of the Lightweight Scene Graph Generation FastAPI service (used when
# LANG2ACTION_PERCEPTION=sgg).
LANG2ACTION_SGG_URL=http://localhost:8000

# API key for the provider selected above (only needed for live runs / eval;
# development and tests use a mocked LLM).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
